	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 utest_input_hid
.PHONY : utest_input_hid

# fast build rule for target.
utest_input_hid/fast:
	$(MAKE) $(MAKESILENT) -f src/devices/input_hid/test/CMakeFiles/utest_input_hid.dir/build.make src/devices/input_hid/test/CMakeFiles/utest_input_hid.dir/build
.PHONY : utest_input_hid/fast

