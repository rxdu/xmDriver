# Same syntax as find_package
find_dependency(Threads REQUIRED)

# xmMu is built on top of xmSigma, which provides the xmotion::interface and
# xmotion::logging targets that every driver module links against.
find_dependency(xmSigma REQUIRED)

# Any extra setup

